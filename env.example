# Server
PORT=3000
PUBLIC_URL=https://tu-app.railway.app

# Twilio
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886   # Sandbox: +14155238886 | Produccion: tu numero comprado

# Tu numero personal de WhatsApp (con codigo de pais, sin +)
# Ejemplo Colombia: 573001234567
MY_PHONE_NUMBER=57xxxxxxxxxx

# Supabase
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_public_key

# Google AI (Gemini)
# Get from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# Zona horaria (Colombia)
TZ=America/Bogota
